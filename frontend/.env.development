# 【开发】环境变量

# 应用部署基础路径（如部署在子目录 /admin，则设置为 /admin/）
VITE_BASE_URL = /

# API 请求基础路径（开发环境设置为 / 使用代理，生产环境设置为完整后端地址）
VITE_API_URL = /

# 代理目标地址（开发环境通过 Vite 代理转发 /api 到此地址，须与后端实际运行端口一致）
# 后端默认端口 8080（见 backend/internal/config）；若后端改在 3006 等端口，请改为对应地址
VITE_API_PROXY_URL = http://localhost:8080

# 菜单/权限模式：frontend=前端路由控制，backend=后端菜单接口（按角色过滤侧栏菜单）
VITE_ACCESS_MODE = backend

# Delete console
VITE_DROP_CONSOLE = false
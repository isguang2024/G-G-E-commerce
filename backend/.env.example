# G&G E-commerce backend environment overrides
# 配置加载规则：
# 1. 默认读取 backend/configs/config.example.yaml / config.yaml
# 2. 下面这些环境变量以 GG_ 为前缀覆盖 YAML 配置
# 3. 复制为 .env.local 或在终端导出后再启动服务

GG_ENV=development

# Server
GG_SERVER_HOST=0.0.0.0
GG_SERVER_PORT=8080
GG_SERVER_READ_TIMEOUT=30
GG_SERVER_WRITE_TIMEOUT=30
GG_SERVER_IDLE_TIMEOUT=60

# PostgreSQL
GG_DB_HOST=localhost
GG_DB_PORT=5432
GG_DB_USER=postgres
GG_DB_PASSWORD=postgres
GG_DB_DBNAME=gg_ecommerce
GG_DB_SSLMODE=disable
GG_DB_TIMEZONE=Asia/Shanghai

# Redis
GG_REDIS_HOST=localhost
GG_REDIS_PORT=6379
GG_REDIS_PASSWORD=
GG_REDIS_DB=0

# Elasticsearch（可选，对应 docker compose profile: optional）
GG_ELASTICSEARCH_ADDRESSES=http://localhost:9200
GG_ELASTICSEARCH_USERNAME=
GG_ELASTICSEARCH_PASSWORD=

# MinIO（可选，对应 docker compose profile: optional）
GG_MINIO_ENDPOINT=localhost:9000
GG_MINIO_ACCESS_KEY_ID=minioadmin
GG_MINIO_SECRET_ACCESS_KEY=minioadmin
GG_MINIO_USE_SSL=false
GG_MINIO_BUCKET_NAME=gg-ecommerce

# JWT
# 生产环境必须替换为强随机密钥，禁止继续使用示例值。
GG_JWT_SECRET=your-secret-key-change-in-production
GG_JWT_ACCESS_EXPIRE=10080
GG_JWT_REFRESH_EXPIRE=10080

# Log
GG_LOG_LEVEL=info
GG_LOG_OUTPUT=stdout

# Upload
GG_UPLOAD_LOCAL_ROOT=./data/uploads
GG_UPLOAD_PUBLIC_BASE_URL=/uploads
GG_UPLOAD_DEFAULT_TENANT_ID=default
GG_UPLOAD_DEFAULT_PROVIDER_KEY=local-public
GG_UPLOAD_DEFAULT_BUCKET_KEY=public-media
GG_UPLOAD_DEFAULT_UPLOAD_KEY=media.default
GG_UPLOAD_DEFAULT_RULE_KEY=image
GG_UPLOAD_MAX_FILE_SIZE_BYTES=10485760
GG_UPLOAD_SECRET_MASTER_KEYS=
GG_UPLOAD_SECRET_CACHE_TTL_SECONDS=300
GG_UPLOAD_SECRET_CURRENT_KEY_ID=local
